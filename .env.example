# Copy this to .env and fill in real values. Never commit .env.

# --- GitHub App credentials ---
# Created at https://github.com/settings/apps -> New GitHub App
GITHUB_APP_ID=
GITHUB_APP_WEBHOOK_SECRET=
# Path to the private key (.pem) downloaded from the GitHub App settings.
GITHUB_APP_PRIVATE_KEY_PATH=./private-key.pem

# --- LLM provider ---
# Groq is the default (fast Llama inference). Get a key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# --- Database ---
# SQLite for local dev, Postgres in prod.
DATABASE_URL=sqlite+aiosqlite:///./prsage.db
